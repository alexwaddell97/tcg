{
  "name": "@tcg/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "electron:dev": "concurrently \"cross-env BROWSER=none vite\" \"wait-on http://localhost:5173 && cross-env ELECTRON_START_URL=http://localhost:5173 electron .\"",
    "electron:build": "pnpm run build && electron-builder",
    "electron:build:mac": "pnpm run build && electron-builder --mac",
    "electron:build:win": "pnpm run build && electron-builder --win",
    "electron:build:linux": "pnpm run build && electron-builder --linux"
  },
  "dependencies": {
    "@tcg/shared": "workspace:*",
    "clsx": "^2.1.1",
    "lucide-react": "^0.469.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.1.0",
    "socket.io-client": "^4.8.1",
    "tailwind-merge": "^2.5.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react-swc": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "concurrently": "^9.0.0",
    "cross-env": "^10.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^26.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.9.3",
    "vite": "^6.0.0",
    "wait-on": "^9.0.0"
  },
  "build": {
    "appId": "com.tcg.game",
    "productName": "TCG",
    "directories": {
      "buildResources": "build",
      "output": "../../dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.games"
    },
    "win": {
      "target": [{"target": "nsis", "arch": ["x64"]}]
    },
    "linux": {
      "target": ["AppImage"]
    }
  }
}
